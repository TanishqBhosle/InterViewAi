# ============================================
# InterviewAI India — Environment Variables
# ============================================
# Copy this file to .env in each workspace and fill in your values.
# NEVER commit .env files to version control.

# --- Web Frontend (apps/web/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# --- Server (apps/server/.env) ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Redis — for caching and job queues
REDIS_URL=redis://localhost:6379

# JWT — use strong random secrets (openssl rand -base64 64)
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=7d


# AWS — file uploads via S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=interviewai-uploads

# xAI Grok — AI interview coach & evaluation
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# --- Database Package (packages/database/.env) ---
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
