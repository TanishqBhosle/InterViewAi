// InterviewAI India - Complete Database Schema
// Production-grade Prisma schema with all entities

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  STUDENT
  PREMIUM
  COLLEGE_ADMIN
  ENTERPRISE_ADMIN
  SUPPORT_AGENT
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  OTP
}

enum InterviewType {
  HR
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  PRODUCT_MANAGEMENT
  CASE_STUDY
  SALES
  DATA_SCIENCE
  CUSTOM_COMPANY
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum InterviewStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  EXPIRED
}

enum AnswerMode {
  TEXT
  VOICE
  VIDEO
}


enum ResumeStatus {
  UPLOADED
  PROCESSING
  ANALYZED
  FAILED
}

enum NotificationType {
  INTERVIEW_COMPLETE
  REPORT_READY

  NEW_FEATURE
  SYSTEM
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String       @id @default(uuid()) @db.Uuid
  name          String       @db.VarChar(255)
  email         String       @unique @db.VarChar(255)
  passwordHash  String?      @map("password_hash") @db.Text
  role          UserRole     @default(STUDENT)
  authProvider  AuthProvider @default(EMAIL) @map("auth_provider")
  googleId      String?      @unique @map("google_id") @db.VarChar(255)
  phone         String?      @db.VarChar(20)
  avatarUrl     String?      @map("avatar_url") @db.Text
  emailVerified Boolean      @default(false) @map("email_verified")
  isActive      Boolean      @default(true) @map("is_active")
  lastLoginAt   DateTime?    @map("last_login_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  // Relations
  profile        Profile?
  resumes        Resume[]
  interviews     Interview[]

  notifications  Notification[]
  chatSessions   ChatSession[]
  roadmaps       Roadmap[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]

  // Learning Hub
  progress       UserProgress[]
  notes          UserNote[]

  // DSA Mastery Hub
  dsaProblems         DSAUserProblem[]
  dsaPatternProgress  DSAPatternProgress[]
  dsaMistakeLogs      DSAMistakeLog[]
  dsaRevisionCards    DSARevisionCard[]
  dsaMockInterviews   DSAMockInterview[]
  dsaDailyPlans       DSADailyPlan[]

  // College relation
  collegeId String?  @map("college_id") @db.Uuid
  college   College? @relation(fields: [collegeId], references: [id])

  @@index([email])
  @@index([role])
  @@index([collegeId])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.Text
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, code])
  @@map("otp_codes")
}

// ============================================
// PROFILE
// ============================================

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  bio             String?  @db.Text
  targetRole      String?  @map("target_role") @db.VarChar(255)
  experience      Int?     @default(0)
  currentCompany  String?  @map("current_company") @db.VarChar(255)
  currentRole     String?  @map("current_role") @db.VarChar(255)
  location        String?  @db.VarChar(255)
  linkedinUrl     String?  @map("linkedin_url") @db.Text
  githubUrl       String?  @map("github_url") @db.Text
  portfolioUrl    String?  @map("portfolio_url") @db.Text
  skills          Json?    @default("[]")
  education       Json?    @default("[]")
  careerGoals     Json?    @default("[]") @map("career_goals")
  targetCompanies Json?    @default("[]") @map("target_companies")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// RESUME
// ============================================

model Resume {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  fileName       String       @map("file_name") @db.VarChar(255)
  fileUrl        String       @map("file_url") @db.Text
  fileSize       Int          @map("file_size")
  mimeType       String       @map("mime_type") @db.VarChar(100)
  status         ResumeStatus @default(UPLOADED)
  atsScore       Int?         @map("ats_score")
  parsedData     Json?        @map("parsed_data")
  skillsFound    Json?        @map("skills_found") @default("[]")
  missingKeywords Json?       @map("missing_keywords") @default("[]")
  weakSections   Json?        @map("weak_sections") @default("[]")
  suggestions    Json?        @default("[]")
  analysisReport Json?        @map("analysis_report")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("resumes")
}

// ============================================
// INTERVIEW ENGINE
// ============================================

model Interview {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  type            InterviewType
  difficulty      InterviewDifficulty @default(MEDIUM)
  role            String              @db.VarChar(255)
  company         String?             @db.VarChar(255)
  status          InterviewStatus     @default(CREATED)
  totalQuestions  Int                 @default(10) @map("total_questions")
  answeredCount   Int                 @default(0) @map("answered_count")
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  duration        Int?                // in seconds
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  report    Report?

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("interviews")
}

model Question {
  id             String @id @default(uuid()) @db.Uuid
  interviewId    String @map("interview_id") @db.Uuid
  questionText   String @map("question_text") @db.Text
  expectedAnswer String? @map("expected_answer") @db.Text
  category       String? @db.VarChar(100)
  difficulty     InterviewDifficulty @default(MEDIUM)
  orderIndex     Int    @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  answer    Answer?

  @@index([interviewId])
  @@map("questions")
}

model Answer {
  id          String     @id @default(uuid()) @db.Uuid
  questionId  String     @unique @map("question_id") @db.Uuid
  answerText  String?    @map("answer_text") @db.Text
  audioUrl    String?    @map("audio_url") @db.Text
  videoUrl    String?    @map("video_url") @db.Text
  mode        AnswerMode @default(TEXT)
  duration    Int?       // in seconds
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  evaluation Evaluation?

  @@map("answers")
}

model Evaluation {
  id                  String @id @default(uuid()) @db.Uuid
  answerId            String @unique @map("answer_id") @db.Uuid
  technicalScore      Float  @map("technical_score")
  communicationScore  Float  @map("communication_score")
  confidenceScore     Float  @map("confidence_score")
  problemSolvingScore Float  @map("problem_solving_score")
  overallScore        Float  @map("overall_score")
  feedback            String? @db.Text
  strengths           Json?  @default("[]")
  improvements        Json?  @default("[]")
  createdAt           DateTime @default(now()) @map("created_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("evaluations")
}

model Report {
  id              String @id @default(uuid()) @db.Uuid
  interviewId     String @unique @map("interview_id") @db.Uuid
  overallScore    Float  @map("overall_score")
  technicalScore  Float  @map("technical_score")
  communicationScore Float @map("communication_score")
  confidenceScore Float  @map("confidence_score")
  leadershipScore Float? @map("leadership_score")
  problemSolvingScore Float? @map("problem_solving_score")
  strengths       Json   @default("[]")
  weaknesses      Json   @default("[]")
  recommendations Json   @default("[]")
  detailedFeedback String? @map("detailed_feedback") @db.Text
  speechAnalysis  Json?  @map("speech_analysis")
  videoAnalysis   Json?  @map("video_analysis")
  createdAt       DateTime @default(now()) @map("created_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("reports")
}

// ============================================
// AI CAREER COACH
// ============================================

model ChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(255)
  context   String?  @db.VarChar(100) // resume_help, interview_prep, career_guidance, etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String @id @default(uuid()) @db.Uuid
  sessionId     String @map("session_id") @db.Uuid
  role          String @db.VarChar(20) // user, assistant
  content       String @db.Text
  tokenCount    Int?   @map("token_count")
  createdAt     DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ============================================
// ROADMAPS
// ============================================

model Roadmap {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  title     String @db.VarChar(255)
  duration  String @db.VarChar(50) // 7_day, 30_day, 90_day
  plan      Json   @default("[]")
  progress  Int    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("roadmaps")
}


// ============================================
// COLLEGE
// ============================================

model College {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  code        String   @unique @db.VarChar(50)
  location    String?  @db.VarChar(255)
  website     String?  @db.Text
  logoUrl     String?  @map("logo_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("colleges")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================
// LEARNING HUB - Content Hierarchy
// ============================================

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  icon        String   @default("BookOpen") @db.VarChar(50)
  color       String?  @db.VarChar(50)
  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  topics    Topic[]
  resources LearningResource[]

  @@map("subjects")
}

model Topic {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @db.VarChar(200)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  order       Int      @default(0)
  subjectId   String   @map("subject_id") @db.Uuid
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subtopics Subtopic[]

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@map("topics")
}

model Subtopic {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @db.VarChar(200)
  title       String   @db.VarChar(200)
  order       Int      @default(0)
  topicId     String   @map("topic_id") @db.Uuid
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  content     Json     @default("{}")
  quiz        Json     @default("[]")
  faangQuestions Json  @default("[]") @map("faang_questions")
  codingChallenges Json @default("[]") @map("coding_challenges")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  progress   UserProgress[]
  notes      UserNote[]

  @@unique([topicId, slug])
  @@index([topicId])
  @@map("subtopics")
}

// ============================================
// LEARNING HUB - User Progress & Notes
// ============================================

model UserProgress {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  subtopicId String   @map("subtopic_id") @db.Uuid
  status     String   @default("not_started") @db.VarChar(20) // not_started, in_progress, completed
  score      Float?   // quiz score percentage
  completedAt DateTime? @map("completed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  @@unique([userId, subtopicId])
  @@index([userId])
  @@map("user_progress")
}

model UserNote {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  subtopicId String   @map("subtopic_id") @db.Uuid
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  @@index([userId, subtopicId])
  @@map("user_notes")
}

// ============================================
// LEARNING HUB - Legacy Resources
// ============================================

model LearningResource {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  subcategory String?  @db.VarChar(100)
  content     String   @db.Text
  company     String?  @db.VarChar(100)
  difficulty  InterviewDifficulty @default(MEDIUM)
  tags        Json     @default("[]")
  viewCount   Int      @default(0) @map("view_count")
  isPremium   Boolean  @default(false) @map("is_premium")
  subjectId   String?  @map("subject_id") @db.Uuid
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([company])
  @@index([subjectId])
  @@map("learning_resources")
}

// ============================================
// AUDIT & ANALYTICS
// ============================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @map("entity_id") @db.VarChar(255)
  metadata  Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  event     String   @db.VarChar(100)
  userId    String?  @map("user_id") @db.Uuid
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ============================================
// DSA MASTERY HUB
// ============================================

enum DSAProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DSAProblemStatus {
  NOT_STARTED
  ATTEMPTED
  SOLVED
  REVIEW
  MASTERED
}

enum DSAPhase {
  FOUNDATIONS
  LINEAR_PATTERNS
  SEARCHING
  HIERARCHICAL
  ADVANCED
  OPTIMIZATION
}

model DSAPattern {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique @db.VarChar(100)
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  phase           DSAPhase
  order           Int       @default(0)
  icon            String    @default("Code2") @db.VarChar(50)
  color           String?   @db.VarChar(50)
  recognitionSignals Json?  @map("recognition_signals")
  decisionTree    Json?     @map("decision_tree")
  codeTemplate    String?   @map("code_template") @db.Text
  whenToUse       String?   @map("when_to_use") @db.Text
  whenNotToUse    String?   @map("when_not_to_use") @db.Text
  commonMistakes  Json?     @map("common_mistakes")
  variations      Json?
  realLifeAnalogy String?   @map("real_life_analogy") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  problems        DSAProblem[]
  userProgress    DSAPatternProgress[]

  @@index([phase])
  @@index([order])
  @@map("dsa_patterns")
}

model DSAProblem {
  id              String            @id @default(uuid()) @db.Uuid
  leetcodeId      Int?              @unique @map("leetcode_id")
  title           String            @db.VarChar(300)
  slug            String            @db.VarChar(300)
  difficulty      DSAProblemDifficulty @default(MEDIUM)
  description     String?           @db.Text
  patternId       String?           @map("pattern_id") @db.Uuid
  tier            Int               @default(2) // 1=Must Solve, 2=Pattern, 3=Company, 4=FAANG
  companies       Json @default("[]")
  tags            Json @default("[]")
  hints           Json?
  bruteForce      String?           @map("brute_force") @db.Text
  optimalSolution String?           @map("optimal_solution") @db.Text
  timeComplexity  String?           @map("time_complexity") @db.VarChar(50)
  spaceComplexity String?           @map("space_complexity") @db.VarChar(50)
  dryRun          Json?
  commonMistakes  Json?             @map("common_mistakes")
  followUps       Json?             @map("follow_ups")
  productionUse   String?           @map("production_use") @db.Text
  expectedTime    Int?              @map("expected_time") // minutes
  revisionFrequency Int?            @map("revision_frequency") // days
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  pattern         DSAPattern?       @relation(fields: [patternId], references: [id], onDelete: SetNull)
  userProblems    DSAUserProblem[]
  mistakeLogs     DSAMistakeLog[]
  revisionCards   DSARevisionCard[]
  companyProblems DSACompanyProblem[]
  mockQuestions    DSAMockQuestion[]

  @@index([patternId])
  @@index([difficulty])
  @@index([tier])
  @@index([leetcodeId])
  @@map("dsa_problems")
}

model DSAUserProblem {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  problemId     String           @map("problem_id") @db.Uuid
  status        DSAProblemStatus @default(NOT_STARTED)
  attempts      Int              @default(0)
  bestTime      Int?             @map("best_time") // seconds
  lastAttemptAt DateTime?        @map("last_attempt_at")
  solvedAt      DateTime?        @map("solved_at")
  notes         String?          @db.Text
  code          String?          @db.Text
  language      String?          @db.VarChar(20)
  confidence    Int              @default(0) // 0-100
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem DSAProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@map("dsa_user_problems")
}

model DSAPatternProgress {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  patternId     String   @map("pattern_id") @db.Uuid
  solved        Int      @default(0)
  total         Int      @default(0)
  mastery       Float    @default(0) // 0-100
  lastPracticed DateTime? @map("last_practiced")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern DSAPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([userId, patternId])
  @@index([userId])
  @@map("dsa_pattern_progress")
}

model DSAMistakeLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  problemId     String   @map("problem_id") @db.Uuid
  coreMistake   String?  @map("core_mistake") @db.Text
  patternMissed String?  @map("pattern_missed") @db.VarChar(200)
  rootCause     String?  @map("root_cause") @db.Text
  fixStrategy   String?  @map("fix_strategy") @db.Text
  revisitDate   DateTime? @map("revisit_date")
  confidence    Int      @default(0) // 0-100
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem DSAProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
  @@index([revisitDate])
  @@map("dsa_mistake_logs")
}

model DSARevisionCard {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  problemId     String   @map("problem_id") @db.Uuid
  nextReview    DateTime @map("next_review")
  interval      Int      @default(1) // days
  ease          Float    @default(2.5)
  reviews       Int      @default(0)
  lastReview    DateTime? @map("last_review")
  rating        Int      @default(0) // 0-5 (SM-2 scale)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem DSAProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([nextReview])
  @@map("dsa_revision_cards")
}

model DSACompanyTrack {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique @db.VarChar(100)
  name          String   @db.VarChar(200)
  logo          String?  @db.Text
  description   String?  @db.Text
  problemCount  Int      @default(0) @map("problem_count")
  avgDifficulty String?  @map("avg_difficulty") @db.VarChar(20)
  frequency     Json? // pattern frequencies
  strategy      String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  problems DSACompanyProblem[]

  @@map("dsa_company_tracks")
}

model DSACompanyProblem {
  id        String   @id @default(uuid()) @db.Uuid
  trackId   String   @map("track_id") @db.Uuid
  problemId String   @map("problem_id") @db.Uuid
  order     Int      @default(0)
  frequency Int      @default(0) // times asked
  createdAt DateTime @default(now()) @map("created_at")

  track   DSACompanyTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  problem DSAProblem      @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([trackId, problemId])
  @@index([trackId])
  @@map("dsa_company_problems")
}

model DSAMockInterview {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  title         String   @db.VarChar(200)
  duration      Int      @default(45) // minutes
  questionCount Int      @default(5) @map("question_count")
  difficulty    DSAProblemDifficulty @default(MEDIUM)
  patterns      Json @default("[]")
  status        String   @default("created") @db.VarChar(20)
  score         Float?
  feedback      String?  @db.Text
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions DSAMockQuestion[]

  @@index([userId])
  @@index([status])
  @@map("dsa_mock_interviews")
}

model DSAMockQuestion {
  id           String   @id @default(uuid()) @db.Uuid
  interviewId  String   @map("interview_id") @db.Uuid
  problemId    String   @map("problem_id") @db.Uuid
  orderIndex   Int      @map("order_index")
  timeLimit    Int      @default(600) @map("time_limit") // seconds
  userAnswer   String?  @map("user_answer") @db.Text
  userTime     Int?     @map("user_time") // seconds
  score        Float?
  feedback     String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  interview DSAMockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  problem   DSAProblem       @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("dsa_mock_questions")
}

model DSADailyPlan {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  date        DateTime @db.Date
  duration    Int      @default(60) // minutes
  plan        Json @default("[]")
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("dsa_daily_plans")
}

